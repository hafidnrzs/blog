---
import BaseHead from '@components/BaseHead.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="500 - Terjadi Kesalahan"
      description="Terjadi kesalahan pada server."
    />
    <style>
      main {
        min-height: calc(100vh - 4rem);
        display: flex;
        align-items: center;
      }
      @media (width >= 48rem) {
        main {
          border-inline: 1px solid var(--color-gray-02);
        }
      }
      .error-page {
        padding-block: 6rem;
        text-align: center;
        width: 100%;
      }
      .error-code {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 6rem;
        font-weight: 800;
        line-height: 1;
        margin: 0;
        color: var(--color-gray-03);
      }
      @media (width >= 48rem) {
        .error-code {
          font-size: 10rem;
        }
      }
      .error-title {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        margin-top: 1rem;
        margin-bottom: 0;
      }
      @media (width >= 48rem) {
        .error-title {
          font-size: 2rem;
        }
      }
      .error-description {
        color: var(--color-gray-08);
        font-size: 1rem;
        margin-top: 1rem;
        margin-bottom: 0;
      }
      .back-link {
        display: inline-block;
        margin-top: 2.5rem;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 1rem;
        font-weight: 600;
        color: var(--color-black);
        text-decoration: none;
        border-bottom: 1px solid var(--color-black);
        padding-bottom: 0.25rem;
        &:hover {
          color: var(--color-gray-08);
          border-bottom-color: var(--color-gray-08);
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="container">
      <div class="error-page">
        <p class="error-code">500</p>
        <h1 class="error-title">Terjadi Kesalahan</h1>
        <p class="error-description">
          Terjadi kesalahan pada server. Coba lagi beberapa saat.
        </p>
        <a href="/" class="back-link">Kembali ke Beranda</a>
      </div>
    </main>
    <Footer />
  </body>
</html>
