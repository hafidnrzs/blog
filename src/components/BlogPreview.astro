---
import { getCollection } from 'astro:content';

import FormattedDate from '@components/FormattedDate.astro';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const posts = allPosts.slice(0, 4);
---

<section id="blog-preview" class="container">
  <h3 class="title font-sans">Blog</h3>
  <header class="header">
    <span class="highlight">Inspirasi Harian<br />dari Blog-ku</span>
    <p class="font-sans">
      Halo, aku Hafid Nur, seorang full-stack developer. Aku menulis tentang
      pemrograman dan AI/Machine learning
    </p>
  </header>
  <span class="latest-article">Artikel Terbaru</span>
  <div class="posts-grid">
    {
      posts.map((post) => (
        <article>
          <a href={`/blog/${post.id}/`}>
            <img src={post.data.heroImage} alt={post.data.title} />
            <FormattedDate date={post.data.pubDate} />
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
          </a>
        </article>
      ))
    }
  </div>
  <div class="see-articles">
    <a href="/blog" class="btn btn--outline">Lihat Semua Artikel</a>
  </div>

  <style>
    #blog-preview {
      padding-block: 6rem;
    }
    @media (min-width: 768px) {
      .container {
        border-inline: 1px solid var(--color-gray-02);
      }
    }
    /* Tablet (768px and up) */
    @media (width >= 48rem) {
      .header .highlight {
        font-size: 4rem;
      }
    }
    .header {
      display: flex;
      flex-direction: column;
      text-align: center;
      gap: 1.5rem;
      .highlight {
        font-size: 2rem;
        line-height: 1.25;
      }
      p {
        color: var(--color-gray-08);
        font-size: 1rem;
        max-width: 600px;
        margin: 0 auto;
      }
    }
    h3.title {
      text-align: center;
      font-size: 1rem;
      color: var(--color-gray-08);
      text-transform: uppercase;
    }
    .latest-article {
      display: block;
      font-size: 2rem;
      line-height: 100%;
      margin-top: 2.5rem;
      margin-bottom: 1.5rem;
    }
    .posts-grid {
      display: grid;
      grid-template-columns: var(--grid-columns);
      column-gap: 1rem;
      row-gap: 2rem;
    }
    article a {
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      img {
        width: 100%;
        max-width: 1200px;
        aspect-ratio: 1.91 / 1;
        object-fit: cover;
      }
      time {
        color: var(--color-gray-08);
        font-size: 1rem;
      }
      h2 {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 1.25rem;
        font-weight: bold;
        line-height: 1.75;
      }
      p {
        font-size: 1rem;
        color: var(--color-gray-08);
        margin: 0;
      }
    }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 40px;
      padding-inline: 24px;
      text-decoration: none;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      background-color: var(--color-black);
      color: var(--color-white);
      &:hover {
        opacity: 0.85;
      }
    }
    .see-articles {
      width: 100%;
      display: flex;
      justify-content: center;
      margin-top: 2.5rem;
    }
    .btn--outline {
      background-color: transparent;
      color: var(--color-black);
      border: 1px solid var(--color-black);
      &:hover {
        background-color: var(--color-neutral-02);
        color: var(--color-black);
      }
    }
  </style>
</section>
